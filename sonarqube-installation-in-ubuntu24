#!/bin/bash

set -e

SONAR_VERSION="10.5.1.90531"
SONAR_ZIP="sonarqube-${SONAR_VERSION}.zip"
SONAR_URL="https://binaries.sonarsource.com/Distribution/sonarqube/${SONAR_ZIP}"

echo "==============================="
echo "Updating Packages"
echo "==============================="

sudo apt update -y

echo "==============================="
echo "Installing Java"
echo "==============================="

sudo apt install -y openjdk-17-jdk wget unzip curl

java -version

echo "==============================="
echo "Installing PostgreSQL"
echo "==============================="

sudo apt install -y postgresql postgresql-contrib

sudo systemctl enable postgresql
sudo systemctl start postgresql

echo "==============================="
echo "Creating Database"
echo "==============================="

sudo -u postgres psql <<EOF

DROP DATABASE IF EXISTS sonarqube;
DROP ROLE IF EXISTS sonar;

CREATE ROLE sonar LOGIN PASSWORD 'sonar123';
CREATE DATABASE sonarqube OWNER sonar;

\c sonarqube

ALTER SCHEMA public OWNER TO sonar;

GRANT ALL ON SCHEMA public TO sonar;

GRANT ALL PRIVILEGES ON DATABASE sonarqube TO sonar;

ALTER DEFAULT PRIVILEGES IN SCHEMA public
GRANT ALL ON TABLES TO sonar;

ALTER DEFAULT PRIVILEGES IN SCHEMA public
GRANT ALL ON SEQUENCES TO sonar;

ALTER DEFAULT PRIVILEGES IN SCHEMA public
GRANT ALL ON FUNCTIONS TO sonar;

EOF

echo "==============================="
echo "Creating Sonar User"
echo "==============================="

if ! id sonar >/dev/null 2>&1; then
    sudo useradd -r -m -d /opt/sonarqube -s /bin/bash sonar
fi

echo "==============================="
echo "Removing Old Installation"
echo "==============================="

sudo rm -rf /opt/sonarqube

echo "==============================="
echo "Downloading SonarQube"
echo "==============================="

cd /tmp

wget -O ${SONAR_ZIP} ${SONAR_URL}

echo "==============================="
echo "Extracting SonarQube"
echo "==============================="

sudo unzip -q ${SONAR_ZIP} -d /opt

sudo mv /opt/sonarqube-${SONAR_VERSION} /opt/sonarqube

sudo chown -R sonar:sonar /opt/sonarqube

echo "==============================="
echo "Configuring SonarQube"
echo "==============================="

sudo tee -a /opt/sonarqube/conf/sonar.properties >/dev/null <<EOF

sonar.jdbc.username=sonar
sonar.jdbc.password=sonar123
sonar.jdbc.url=jdbc:postgresql://localhost:5432/sonarqube

EOF

echo "==============================="
echo "Kernel Configuration"
echo "==============================="

echo "vm.max_map_count=524288" | sudo tee /etc/sysctl.d/99-sonarqube.conf

echo "fs.file-max=131072" | sudo tee -a /etc/sysctl.d/99-sonarqube.conf

sudo sysctl --system

echo "==============================="
echo "Limits Configuration"
echo "==============================="

sudo tee /etc/security/limits.d/99-sonarqube.conf >/dev/null <<EOF
sonar soft nofile 131072
sonar hard nofile 131072
sonar soft nproc 8192
sonar hard nproc 8192
EOF

echo "==============================="
echo "Creating Service"
echo "==============================="

sudo tee /etc/systemd/system/sonarqube.service >/dev/null <<EOF
[Unit]
Description=SonarQube
After=network.target postgresql.service

[Service]
Type=forking

User=sonar
Group=sonar

ExecStart=/opt/sonarqube/bin/linux-x86-64/sonar.sh start
ExecStop=/opt/sonarqube/bin/linux-x86-64/sonar.sh stop

Restart=always
RestartSec=10

LimitNOFILE=131072
LimitNPROC=8192

[Install]
WantedBy=multi-user.target
EOF

echo "==============================="
echo "Reloading Systemd"
echo "==============================="

sudo systemctl daemon-reload

sudo systemctl enable sonarqube

echo "==============================="
echo "Starting SonarQube"
echo "==============================="

sudo systemctl restart sonarqube

sleep 15

echo "==============================="
echo "Service Status"
echo "==============================="

sudo systemctl status sonarqube --no-pager

echo
echo "======================================"
echo "SonarQube URL:"
echo "http://<EC2-PUBLIC-IP>:9000"
echo
echo "Default Username : admin"
echo "Default Password : admin"
echo "======================================"
